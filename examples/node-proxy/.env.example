# Server encryption secret — min 16 chars. NEVER commit real values.
PROXY_ENCRYPTION_SECRET=change-me-in-production
PORT=3920

# Optional Google OAuth → Gemini (v0.3)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3920/account-bridge/oauth/google/callback

# Optional Microsoft OAuth → Microsoft Copilot (M365 Copilot Chat API)
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT_ID=common
# MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3920/account-bridge/oauth/microsoft/callback
