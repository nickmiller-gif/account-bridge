# Copy to .env — NEVER commit .env

# AES key derivation secret for encrypted credential files
ACCOUNT_BRIDGE_ENCRYPTION_SECRET=change-me-local-dev

# Optional user id namespace (defaults to "mcp-default")
# ACCOUNT_BRIDGE_USER_ID=operator-1

# Optional custom storage directory (defaults to ~/.account-bridge/mcp)
# ACCOUNT_BRIDGE_STORAGE_DIR=
