{
  "name": "@account-bridge/mcp",
  "version": "3.0.0",
  "description": "MCP stdio server — connect user AI keys and run chat from Cursor/agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "account-bridge-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@account-bridge/core": "3.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
