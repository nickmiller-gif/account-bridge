{
  "name": "@account-bridge/overlay",
  "version": "3.0.0",
  "description": "Framework-agnostic Account Bridge overlay — FAB + funding gate on any page",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@account-bridge/core": "3.0.0",
    "@account-bridge/ui": "3.0.0",
    "@account-bridge/web": "3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
