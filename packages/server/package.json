{
  "name": "@account-bridge/server",
  "version": "3.0.0",
  "description": "Account Bridge server — SQL credential store and OAuth PKCE routes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase/index.d.ts",
      "import": "./dist/supabase/index.js"
    }
  },
  "files": [
    "dist",
    "supabase"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@account-bridge/adapters": "3.0.0",
    "@account-bridge/billing": "3.0.0",
    "@account-bridge/core": "3.0.0",
    "@account-bridge/gateway": "3.0.0",
    "@account-bridge/platform": "3.1.0"
  },
  "peerDependencies": {
    "express": ">=4.18.0",
    "pg": ">=8.11.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
